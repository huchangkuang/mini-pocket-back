# 服务端口
PORT=3035

# 运行环境: development | production | test
NODE_ENV=development

# MySQL 连接（请替换为实际账号密码）
DATABASE_URL="mysql://root:password@localhost:3306/mini_pocket"

# 微信小程序
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# CORS 允许的来源，逗号分隔
CORS_ORIGINS=*

# 对象存储。开发可设 STORAGE_MOCK=true 跳过真实 OSS
# 目录约定：avatars/{userId}/ 头像永久；temp/{userId}/ 临时（7天清理）；feedback/{userId}/ 反馈图永久
STORAGE_MOCK=true
OSS_REGION=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_ENDPOINT=
# 可选：公开读 CDN 域名，配置后 avatarUrl 使用永久链接
OSS_PUBLIC_BASE=
