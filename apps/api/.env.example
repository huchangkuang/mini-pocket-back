# 服务端口
PORT=3035

# 运行环境: development | production | test
NODE_ENV=development

# MySQL 连接（请替换为实际账号密码）
DATABASE_URL="mysql://root:password@localhost:3306/mini_pocket"

# 微信小程序
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# CORS 允许的来源，逗号分隔
CORS_ORIGINS=*
