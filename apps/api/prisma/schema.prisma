generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Accent {
  primary
  secondary
  tertiary
}

model Category {
  id        Int    @id @default(autoincrement())
  code      String @unique
  label     String
  sortOrder Int    @default(0) @map("sort_order")
  tools     Tool[]

  @@map("categories")
}

model Tool {
  id          Int            @id @default(autoincrement())
  routePath   String         @unique @map("route_path")
  name        String
  description String
  iconKey     String         @map("icon_key")
  accent      Accent
  categoryId  Int            @map("category_id")
  category    Category       @relation(fields: [categoryId], references: [id])
  heatScore   Int            @default(0) @map("heat_score")
  enabled     Boolean        @default(true)
  sortOrder   Int            @default(0) @map("sort_order")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  favorites   UserFavorite[]
  usages      UserToolUsage[]

  @@index([categoryId, enabled, heatScore])
  @@map("tools")
}

model User {
  id                      Int                   @id @default(autoincrement())
  openid                  String                @unique
  unionid                 String?               @unique
  nickname                String?
  avatarUrl               String?               @db.Text @map("avatar_url")
  totalXp                 Int                   @default(0) @map("total_xp")
  createdAt               DateTime              @default(now()) @map("created_at")
  updatedAt               DateTime              @updatedAt @map("updated_at")
  favorites               UserFavorite[]
  activeDays              UserActiveDay[]
  toolUsages              UserToolUsage[]
  decisions               UserDecision[]
  feedbacks               Feedback[]
  games                   Game[]
  guesses                 GameGuess[]
  mahjongSessionsCreated  MahjongSession[]      @relation("MahjongSessionCreator")
  mahjongParticipations   MahjongParticipant[]
  mahjongRoundsUpdated    MahjongRound[]        @relation("MahjongRoundUpdater")

  @@map("users")
}

model UserFavorite {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  toolId    Int      @map("tool_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool      Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, toolId])
  @@map("user_favorites")
}

model UserActiveDay {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  activeDate DateTime @db.Date @map("active_date")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([userId, activeDate])
  @@map("user_active_days")
}

model UserToolUsage {
  id            Int       @id @default(autoincrement())
  userId        Int       @map("user_id")
  toolId        Int       @map("tool_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool          Tool      @relation(fields: [toolId], references: [id], onDelete: Cascade)
  firstUsedAt   DateTime  @default(now()) @map("first_used_at")
  lastUsedAt    DateTime  @updatedAt @map("last_used_at")
  dailyUseCount Int       @default(0) @map("daily_use_count")
  dailyUseDate  DateTime? @db.Date @map("daily_use_date")

  @@unique([userId, toolId])
  @@map("user_tool_usages")
}

model LevelConfig {
  level     Int    @id
  minXp     Int    @map("min_xp")
  title     String
  sortOrder Int    @default(0) @map("sort_order")

  @@map("level_configs")
}

model UserDecision {
  id         Int       @id @default(autoincrement())
  userId     Int       @map("user_id")
  title      String
  options    Json
  isActive   Boolean   @default(false) @map("is_active")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([userId, lastUsedAt])
  @@map("user_decisions")
}

enum FeedbackType {
  feature
  performance
  style
  other
}

enum FeedbackStatus {
  pending
  processing
  resolved
  closed
}

model Feedback {
  id        Int            @id @default(autoincrement())
  userId    Int            @map("user_id")
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      FeedbackType
  content   String         @db.VarChar(200)
  contact   String?        @db.VarChar(100)
  imageUrls Json           @default("[]") @map("image_urls")
  status    FeedbackStatus @default(pending)
  createdAt DateTime       @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("feedbacks")
}

enum GameStatus {
  waiting
  won
}

model Game {
  id         String      @id @default(cuid())
  creatorId  Int         @map("creator_id")
  creator    User        @relation(fields: [creatorId], references: [id])
  targetHash String      @map("target_hash")
  status     GameStatus  @default(waiting)
  createdAt  DateTime    @default(now()) @map("created_at")
  guesses    GameGuess[]

  @@map("games")
}

model GameGuess {
  id            Int      @id @default(autoincrement())
  gameId        String   @map("game_id")
  game          Game     @relation(fields: [gameId], references: [id])
  userId        Int      @map("user_id")
  user          User     @relation(fields: [userId], references: [id])
  guess         String   @db.VarChar(4)
  result        String   @db.VarChar(4)
  attemptNumber Int      @map("attempt_number")
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([gameId, userId, attemptNumber])
  @@map("game_guesses")
}

enum MahjongSessionStatus {
  active
  ended
}

enum MahjongRoundStatus {
  draft
  committed
}

model MahjongSession {
  id              String                @id @default(cuid())
  code            String                @unique @db.VarChar(16)
  status          MahjongSessionStatus  @default(active)
  createdByUserId Int                   @map("created_by_user_id")
  createdBy       User                  @relation("MahjongSessionCreator", fields: [createdByUserId], references: [id])
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")
  endedAt         DateTime?             @map("ended_at")
  participants    MahjongParticipant[]
  rounds          MahjongRound[]
  inviteCode      MahjongInviteCode?

  @@index([status, updatedAt])
  @@map("mahjong_sessions")
}

model MahjongParticipant {
  id         Int            @id @default(autoincrement())
  sessionId  String         @map("session_id")
  session    MahjongSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId     Int            @map("user_id")
  user       User           @relation(fields: [userId], references: [id])
  seatIndex  Int            @map("seat_index")
  nickname   String?
  avatarUrl  String?        @db.Text @map("avatar_url")
  joinedAt   DateTime       @default(now()) @map("joined_at")

  @@unique([sessionId, userId])
  @@unique([sessionId, seatIndex])
  @@map("mahjong_participants")
}

model MahjongRound {
  id              Int                 @id @default(autoincrement())
  sessionId       String              @map("session_id")
  session         MahjongSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  status          MahjongRoundStatus  @default(draft)
  roundNo         Int?                @map("round_no")
  score0          Int?                @map("score_0")
  score1          Int?                @map("score_1")
  score2          Int?                @map("score_2")
  score3          Int?                @map("score_3")
  updatedByUserId Int?                @map("updated_by_user_id")
  updatedBy       User?               @relation("MahjongRoundUpdater", fields: [updatedByUserId], references: [id])
  updatedAt       DateTime            @updatedAt @map("updated_at")
  committedAt     DateTime?           @map("committed_at")
  createdAt       DateTime            @default(now()) @map("created_at")

  @@index([sessionId, status])
  @@index([sessionId, roundNo])
  @@map("mahjong_rounds")
}

model MahjongInviteCode {
  id        Int            @id @default(autoincrement())
  scene     String         @unique @db.VarChar(32)
  sessionId String         @unique @map("session_id")
  session   MahjongSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now()) @map("created_at")

  @@map("mahjong_invite_codes")
}
