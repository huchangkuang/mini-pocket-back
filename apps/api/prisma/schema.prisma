generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Accent {
  primary
  secondary
  tertiary
}

model Category {
  id        Int    @id @default(autoincrement())
  code      String @unique
  label     String
  sortOrder Int    @default(0) @map("sort_order")
  tools     Tool[]

  @@map("categories")
}

model Tool {
  id          Int            @id @default(autoincrement())
  routePath   String         @unique @map("route_path")
  name        String
  description String
  iconKey     String         @map("icon_key")
  accent      Accent
  categoryId  Int            @map("category_id")
  category    Category       @relation(fields: [categoryId], references: [id])
  heatScore   Int            @default(0) @map("heat_score")
  enabled     Boolean        @default(true)
  sortOrder   Int            @default(0) @map("sort_order")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  favorites   UserFavorite[]
  usages      UserToolUsage[]

  @@index([categoryId, enabled, heatScore])
  @@map("tools")
}

model User {
  id         Int             @id @default(autoincrement())
  openid     String          @unique
  unionid    String?         @unique
  nickname   String?
  avatarUrl  String?         @db.Text @map("avatar_url")
  totalXp    Int             @default(0) @map("total_xp")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  favorites  UserFavorite[]
  activeDays UserActiveDay[]
  toolUsages UserToolUsage[]
  decisions  UserDecision[]
  feedbacks  Feedback[]

  @@map("users")
}

model UserFavorite {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  toolId    Int      @map("tool_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool      Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, toolId])
  @@map("user_favorites")
}

model UserActiveDay {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  activeDate DateTime @db.Date @map("active_date")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([userId, activeDate])
  @@map("user_active_days")
}

model UserToolUsage {
  id            Int       @id @default(autoincrement())
  userId        Int       @map("user_id")
  toolId        Int       @map("tool_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool          Tool      @relation(fields: [toolId], references: [id], onDelete: Cascade)
  firstUsedAt   DateTime  @default(now()) @map("first_used_at")
  lastUsedAt    DateTime  @updatedAt @map("last_used_at")
  dailyUseCount Int       @default(0) @map("daily_use_count")
  dailyUseDate  DateTime? @db.Date @map("daily_use_date")

  @@unique([userId, toolId])
  @@map("user_tool_usages")
}

model LevelConfig {
  level     Int    @id
  minXp     Int    @map("min_xp")
  title     String
  sortOrder Int    @default(0) @map("sort_order")

  @@map("level_configs")
}

model UserDecision {
  id         Int       @id @default(autoincrement())
  userId     Int       @map("user_id")
  title      String
  options    Json
  isActive   Boolean   @default(false) @map("is_active")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([userId, lastUsedAt])
  @@map("user_decisions")
}

enum FeedbackType {
  feature
  performance
  style
  other
}

enum FeedbackStatus {
  pending
  processing
  resolved
  closed
}

model Feedback {
  id        Int            @id @default(autoincrement())
  userId    Int            @map("user_id")
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      FeedbackType
  content   String         @db.VarChar(200)
  contact   String?        @db.VarChar(100)
  imageUrls Json           @default("[]") @map("image_urls")
  status    FeedbackStatus @default(pending)
  createdAt DateTime       @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("feedbacks")
}
