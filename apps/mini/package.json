    "@tarojs/plugin-framework-react": "4.2.0",
    "@tarojs/plugin-platform-weapp": "4.2.0",
    "@tarojs/react": "4.2.0",
    "@tarojs/runtime": "4.2.0",
    "@tarojs/shared": "4.2.0",
    "@tarojs/taro": "4.2.0",
    "classnames": "^2.3.2",
    "dayjs": "^1.11.10",
    "exceljs": "^4.4.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
