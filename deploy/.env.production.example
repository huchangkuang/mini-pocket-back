# 生产环境变量模板
# 复制到 apps/api/.env 后填写真实值

PORT=3035
NODE_ENV=production

# Docker Compose 内置 MySQL 时使用:
# DATABASE_URL="mysql://mini_pocket:你的密码@mysql:3306/mini_pocket"
# 服务器本机 MySQL 时使用:
DATABASE_URL="mysql://mini_pocket:你的密码@127.0.0.1:3306/mini_pocket"

WECHAT_APP_ID=
WECHAT_APP_SECRET=

JWT_SECRET=请替换为足够长的随机字符串
JWT_EXPIRES_IN=7d

# 生产环境建议限制来源，微信小程序无需浏览器 CORS，可留空或按需配置
CORS_ORIGINS=
